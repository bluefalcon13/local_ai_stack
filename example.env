# --- Pathing (The Portal) ---
CONFIG_ROOT=/var/lib/localaistack-configs
CERT_DIR=/data

# --- Hardware GIDs ---
VIDEO_GID=44    # Replace with your 'video' GID from step 1
RENDER_GID=990  # Replace with your 'render' GID from step 1
APEX_GID=963

# --- Service User ---
SERVICE_UID=1100
SERVICE_USER=ai-svc
HUGGING_FACE_TOKEN=long_random_hex_value

# --- Domain & Security ---
DOMAIN_NAME=some.ai.dev
CLOUDFLARE_TUNNEL_TOKEN=long_random_hex_value
TLS_CLIENT_CERT_NAME=cert.pem
TLS_CLIENT_KEY_NAME=key.pem
CLOUDFLARE_AUTH_ORIGIN_PULL_CERT_NAME=authenticated_origin_pull_ca.pem
CLOUDFLARE_EMAIL=some_email@example.com

# --- IDENTITY & NETWORK ---
WEBUI_SECRET=long_random_hex_value
WEBUI_ADMIN_EMAIL=some_email@example.com
WEBUI_ADMIN_PASSWORD=long_random_hex_value

# --- GOOGLE OAUTH ---
GOOGLE_ID=long_random_hex_value.apps.googleusercontent.com
GOOGLE_SECRET=long_random_hex_value
# --- DATABASE (LangGraph) ---
LANG_POSTGRES_USER=pguser_admin
LANG_POSTGRES_PASSWORD=secure_db_password
LANG_POSTGRES_DB=langgraph_state

# --- SEARCH & TRACING (New Secrets) ---
# SearXNG needs a secret to sign its internal requests
SEARXNG_SECRET=long_random_hex_value
# Phoenix tracing auth (if enabled)
PHOENIX_SECRET=third_random_hex

# --- REDIS CONFIG ---
FIRE_REDIS_URL=redis://redis:6379

# === FIRECRAWL SYSTEM CONFIG ===
SELF_HOSTED=true
PORT=3002
HOST=0.0.0.0
BULL_AUTH_KEY=long_random_hex_value
PLAYWRIGHT_MICROSERVICE_URL=http://playwright-service:3000/scrape
SELF_HOSTED_PLAYWRIGHT=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
DB_AUTHENTICATE=true
NUM_WORKERS_PER_QUEUE=2
OCR_ENABLED=false

# POSTGRES_USER= will use in compose file ${SERVICE_USER}
POSTGRES_PASSWORD=long_random_hex_value
POSTGRES_DB=postgres

# LangGraph (The State Machine)
LANG_POSTGRES_USER=langgraph_admin
LANG_POSTGRES_PASSWORD=long_random_hex_value
LANG_POSTGRES_DB=langgraph_state

# Firecrawl (The Scraper)
FIRE_POSTGRES_USER=firecrawl_admin
FIRE_POSTGRES_PASSWORD=long_random_hex_value
FIRE_POSTGRES_DB=firecrawl
# Note: Firecrawl's API might need specific keys if you 
# use non-local LLMs, but for local, keep it simple.

SCRAPE_TIMEOUT=60000
PAGE_TIMEOUT=30000

# VERY IMPORTANT: Limit the 'concurrency' so they don't fight for the bus
NUM_WORKERS=2 
MAX_JOBS_PER_WORKER=5

# === FIRECRAWL SILENCE SECTION ===
# These stop the "Variable not set" vomit on startup
FIRE_API_KEY=long_random_hex_value
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
BLOCK_MEDIA=false
LOGGING_LEVEL=info
OLLAMA_BASE_URL=
MODEL_EMBEDDING_NAME=Qwen3-Embedding-4B-GGUF
OPENAI_API_KEY=
OPENAI_BASE_URL=http://llama-main
MODEL_NAME=gemma-3-27b-it-qat-q4_0-gguf
SUPABASE_URL=
SUPABASE_ANON_TOKEN=
SUPABASE_SERVICE_TOKEN=
SEARXNG_ENDPOINT=http://searxng:8080
SEARXNG_ENGINES=google,duckduckgo,github
SEARXNG_CATEGORIES=general
SELF_HOSTED_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TEST_API_KEY=