# --- 1. Pathing & Permissions ---
CONFIG_ROOT=/var/lib/localaistack-configs
SERVICE_UID=1100
SERVICE_USER=ai-svc

# --- 2. Hardware GIDs (Run: getent group render video apex) ---
VIDEO_GID=
RENDER_GID=
APEX_GID=

# --- 3. Domain & Caddy Networking ---
DOMAIN_NAME=your.fqdn.com
CLOUDFLARE_EMAIL=youremail@provider.com

# --- 4. Cloudflare mTLS Filenames ---
# Files must live in ${CONFIG_ROOT}/caddy/cloudflare_certs/
TLS_CLIENT_CERT_NAME=
TLS_CLIENT_KEY_NAME=
CLOUDFLARE_AUTH_ORIGIN_PULL_CERT_NAME=

# --- 5. Tokens & Access ---
CLOUDFLARE_TUNNEL_TOKEN=
HUGGING_FACE_TOKEN=

# --- 6. Secrets (Generate with: openssl rand -hex 32) ---
WEBUI_SECRET=
SEARXNG_SECRET=
PHOENIX_SECRET=

# --- 7. Databases (LangGraph) ---
POSTGRES_USER=pguser_admin
POSTGRES_PASSWORD=
POSTGRES_DB=langgraph_state

# --- 8. Open WebUI Admin & Auth ---
WEBUI_ADMIN_EMAIL=
WEBUI_ADMIN_PASSWORD=
GOOGLE_ID=
GOOGLE_SECRET=